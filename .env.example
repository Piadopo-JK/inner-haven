# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# -----------------------------------------------------------------------
# LOCAL DEV ONLY — bypass auth when no Supabase session exists.
# Set to 'student' or 'counselor' to view that role's dashboard without login.
# Has NO effect in production (NODE_ENV=production).
# Remove or leave blank to test real auth flows.
# -----------------------------------------------------------------------
# DEV_ROLE=student
# DEV_ROLE=counselor
